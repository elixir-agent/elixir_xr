<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="csrf-token" content={get_csrf_token()} />
  <.live_title default="Vrex Admin">
    {assigns[:page_title]}
  </.live_title>
  <link phx-track-static rel="stylesheet" href={~p"/assets/default.css"} />
  <!-- model-viewer は Phoenix LiveView より先に定義しておく必要がある -->
  <script type="module" src={~p"/assets/js/model-viewer.min.js"}></script>
  <script defer phx-track-static type="text/javascript" src={~p"/assets/js/phoenix.js"}></script>
  <script defer phx-track-static type="text/javascript" src={~p"/assets/js/phoenix_html.js"}></script>
  <script defer phx-track-static type="text/javascript" src={~p"/assets/js/phoenix_live_view.js"}></script>
  <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}></script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:      #020a02;
      --surface: #040f04;
      --border:  #0c280c;
      --primary: #00e676;
      --text:    #c8f0c8;
      --muted:   #3d6b3d;
      --danger:  #ff3d3d;
      --success: #00e676;
      --warn:    #ffb300;
    }
    html, body { height: 100%; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: var(--bg);
      background-image:
        linear-gradient(rgba(0,230,118,.025) 1px, transparent 1px),
        linear-gradient(90deg, rgba(0,230,118,.025) 1px, transparent 1px);
      background-size: 40px 40px;
      color: var(--text);
      display: flex;
      font-size: 14px;
    }

    /* ── Sidebar ── */
    .sidebar {
      width: 220px;
      min-height: 100vh;
      background: var(--surface);
      border-right: 1px solid var(--border);
      display: flex;
      flex-direction: column;
      flex-shrink: 0;
    }
    .sidebar-logo {
      padding: 24px 20px 16px;
      border-bottom: 1px solid var(--border);
    }
    .sidebar-logo h1 {
      color: var(--primary);
      font-size: 1.4rem;
      font-weight: 800;
      letter-spacing: .12em;
      font-family: "Courier New", monospace;
      text-shadow: 0 0 14px rgba(0,230,118,.7), 0 0 28px rgba(0,230,118,.3);
    }
    .sidebar-logo p  { color: var(--muted); font-size: .72rem; margin-top: 2px; letter-spacing: .06em; }
    .sidebar-nav { padding: 12px 0; flex: 1; }
    .nav-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 20px;
      color: var(--muted);
      text-decoration: none;
      border-radius: 0;
      transition: background .15s, color .15s;
      font-size: .875rem;
    }
    .nav-item:hover  { background: rgba(0,230,118,.08); color: var(--text); }
    .nav-item.active {
      background: rgba(0,230,118,.12);
      color: var(--primary);
      border-right: 2px solid var(--primary);
      text-shadow: 0 0 8px rgba(0,230,118,.5);
    }
    .nav-icon { font-size: 1rem; width: 20px; text-align: center; }
    .sidebar-footer {
      padding: 16px 20px;
      border-top: 1px solid var(--border);
    }
    .admin-name { color: var(--muted); font-size: .78rem; margin-bottom: 8px; }
    .btn-logout {
      display: block;
      text-align: center;
      padding: 8px;
      background: transparent;
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--muted);
      text-decoration: none;
      font-size: .8rem;
      cursor: pointer;
      transition: border-color .2s, color .2s;
    }
    .btn-logout:hover { border-color: var(--danger); color: var(--danger); }

    /* ── Main ── */
    .main {
      flex: 1;
      display: flex;
      flex-direction: column;
      overflow: hidden;
    }
    .topbar {
      height: 52px;
      border-bottom: 1px solid var(--primary);
      box-shadow: 0 1px 12px rgba(0,230,118,.15);
      display: flex;
      align-items: center;
      padding: 0 24px;
      background: var(--surface);
      font-size: .85rem;
      color: var(--muted);
      flex-shrink: 0;
    }
    .page-content { flex: 1; overflow-y: auto; padding: 28px; }

    /* ── Flash ── */
    .flash {
      padding: 12px 16px;
      border-radius: 8px;
      margin-bottom: 20px;
      font-size: .875rem;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .flash-info  { background: rgba(0,230,118,.08); border: 1px solid rgba(0,230,118,.3); color: #69ff47; }
    .flash-error { background: rgba(255,61,61,.1);  border: 1px solid rgba(255,61,61,.3);  color: #ff6b6b; }

    /* ── Cards / Tables ── */
    .stat-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 28px; }
    .stat-card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-left: 3px solid var(--primary);
      border-radius: 12px;
      padding: 20px;
      transition: box-shadow .2s;
    }
    .stat-card:hover { box-shadow: 0 0 16px rgba(0,230,118,.2); }
    .stat-label { color: var(--muted); font-size: .78rem; text-transform: uppercase; letter-spacing: .08em; }
    .stat-value { font-size: 2rem; font-weight: 700; margin-top: 6px; font-family: "Courier New", monospace; }
    .stat-sub   { color: var(--muted); font-size: .78rem; margin-top: 4px; }

    .card {
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 12px;
      overflow: hidden;
      margin-bottom: 24px;
      transition: box-shadow .2s;
    }
    .card:hover { box-shadow: 0 0 20px rgba(0,230,118,.1); }
    .card-header {
      padding: 16px 20px;
      border-bottom: 1px solid var(--border);
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .card-title { font-weight: 600; font-size: .95rem; color: var(--primary); letter-spacing: .04em; }
    .card-body  { padding: 0; }

    table { width: 100%; border-collapse: collapse; }
    th {
      text-align: left;
      padding: 10px 16px;
      font-size: .75rem;
      text-transform: uppercase;
      letter-spacing: .05em;
      color: var(--muted);
      border-bottom: 1px solid var(--border);
    }
    td {
      padding: 12px 16px;
      border-bottom: 1px solid rgba(12,40,12,.8);
      font-size: .875rem;
      vertical-align: middle;
    }
    tr:last-child td { border-bottom: none; }
    tr:hover td { background: rgba(0,230,118,.04); }

    /* ── Badges ── */
    .badge {
      display: inline-flex;
      align-items: center;
      padding: 2px 8px;
      border-radius: 99px;
      font-size: .72rem;
      font-weight: 600;
    }
    .badge-green  { background: rgba(0,230,118,.15);  color: #69ff47; }
    .badge-purple { background: rgba(0,230,118,.1);   color: #b9f6ca; }
    .badge-yellow { background: rgba(255,179,0,.15);   color: #ffd740; }
    .badge-red    { background: rgba(255,61,61,.15);   color: #ff6b6b; }
    .badge-gray   { background: rgba(40,80,40,.3);     color: var(--muted); }

    /* ── Buttons ── */
    .btn {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 14px;
      border-radius: 6px;
      font-size: .8rem;
      font-weight: 500;
      cursor: pointer;
      border: none;
      text-decoration: none;
      transition: opacity .2s, box-shadow .2s;
    }
    .btn:hover { opacity: .85; }
    .btn-primary { background: var(--primary); color: #001a00; font-weight: 700; }
    .btn-primary:hover { box-shadow: 0 0 12px rgba(0,230,118,.5); opacity: 1; }
    .btn-danger  { background: var(--danger);  color: #fff; }
    .btn-ghost   { background: transparent; border: 1px solid var(--border); color: var(--text); }
    .btn-ghost:hover { border-color: var(--primary); color: var(--primary); opacity: 1; }

    /* ── Forms ── */
    input[type="text"], input[type="search"], input[type="email"],
    select, textarea {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 6px;
      color: var(--text);
      padding: 8px 12px;
      font-size: .875rem;
      outline: none;
      transition: border-color .2s, box-shadow .2s;
    }
    input:focus, select:focus, textarea:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 2px rgba(0,230,118,.15);
    }
    .search-input { width: 240px; }

    /* ── Script Editor ── */
    .script-editor {
      background: #010a01;
      border: 1px solid var(--border);
      border-radius: 8px;
      font-family: "Fira Code", "Cascadia Code", "Courier New", monospace;
      font-size: .85rem;
      line-height: 1.6;
      padding: 14px;
      width: 100%;
      min-height: 240px;
      color: #69ff47;
      resize: vertical;
    }
    .script-ok  { color: var(--success); font-size: .8rem; margin-top: 6px; }
    .script-err { color: var(--danger);  font-size: .8rem; margin-top: 6px; }

    /* ── Modal ── */
    .modal-backdrop {
      position: fixed; inset: 0;
      background: rgba(0,0,0,.75);
      display: flex; align-items: center; justify-content: center;
      z-index: 100;
    }
    .modal {
      background: var(--surface);
      border: 1px solid var(--primary);
      border-radius: 16px;
      padding: 32px;
      width: 100%;
      max-width: 600px;
      max-height: 80vh;
      overflow-y: auto;
      box-shadow: 0 0 30px rgba(0,230,118,.2);
    }
    .modal-title { font-size: 1.1rem; font-weight: 700; margin-bottom: 20px; color: var(--primary); }
    .form-group  { margin-bottom: 16px; }
    .form-label  { display: block; color: var(--muted); font-size: .78rem; margin-bottom: 6px; }
    .form-input  { width: 100%; }
    .modal-actions { display: flex; gap: 10px; justify-content: flex-end; margin-top: 24px; }

    /* ── Live indicator ── */
    @keyframes pulse { 0%,100% { opacity:1; } 50% { opacity:.4; } }
    @keyframes glow-pulse {
      0%,100% { box-shadow: 0 0 6px rgba(0,230,118,.8); }
      50%      { box-shadow: 0 0 14px rgba(0,230,118,.3); }
    }
    .live-dot {
      display: inline-block;
      width: 8px; height: 8px;
      border-radius: 50%;
      background: var(--primary);
      animation: pulse 2s infinite, glow-pulse 2s infinite;
      margin-right: 6px;
    }
  </style>
</head>
<body>
  <nav class="sidebar">
    <div class="sidebar-logo">
      <h1>Vrex</h1>
      <p>管理ダッシュボード</p>
    </div>
    <div class="sidebar-nav">
      <a href="/admin"        class={"nav-item #{if assigns[:active_nav] == :dashboard, do: "active"}"}>
        <span class="nav-icon">📊</span> ダッシュボード
      </a>
      <a href="/admin/users"  class={"nav-item #{if assigns[:active_nav] == :users, do: "active"}"}>
        <span class="nav-icon">👥</span> ユーザー
      </a>
      <a href="/admin/worlds" class={"nav-item #{if assigns[:active_nav] == :worlds, do: "active"}"}>
        <span class="nav-icon">🌍</span> ワールド
      </a>
      <a href="/admin/items"  class={"nav-item #{if assigns[:active_nav] == :items, do: "active"}"}>
        <span class="nav-icon">📦</span> アイテム
      </a>
      <a href="/admin/rooms"  class={"nav-item #{if assigns[:active_nav] == :rooms, do: "active"}"}>
        <span class="nav-icon">🚪</span> ルーム (ライブ)
      </a>
    </div>
    <div class="sidebar-footer">
      <div class="admin-name">
        <%= assigns[:current_admin] && (assigns[:current_admin].display_name || assigns[:current_admin].username) %>
      </div>
      <form method="post" action="/admin/logout">
        <input type="hidden" name="_csrf_token" value={get_csrf_token()} />
        <input type="hidden" name="_method" value="delete" />
        <button type="submit" class="btn-logout">ログアウト</button>
      </form>
    </div>
  </nav>

  <div class="main">
    <div class="topbar">
      <span class="live-dot"></span>
      Vrex サーバー稼働中
    </div>
    <div class="page-content">
      <%= if flash = Phoenix.Flash.get(@flash, :info) do %>
        <div class="flash flash-info">✓ <%= flash %></div>
      <% end %>
      <%= if flash = Phoenix.Flash.get(@flash, :error) do %>
        <div class="flash flash-error">⚠ <%= flash %></div>
      <% end %>

      {@inner_content}
    </div>
  </div>
</body>
</html>
